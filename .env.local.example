# Neon (serverless Postgres) - Neon console > your project > Connection Details
DATABASE_URL="postgresql://user:password@ep-xxxx.neon.tech/neondb?sslmode=require"

# Neon Auth - Neon console > your project > Auth tab > Configuration ("Auth URL")
NEON_AUTH_BASE_URL="https://ep-xxxx.neonauth.c-9.us-east-1.aws.neon.tech/neondb/auth"
# Generate with: openssl rand -base64 32 (must be 32+ characters)
NEON_AUTH_COOKIE_SECRET=""

# Resend - resend.com > API Keys
RESEND_API_KEY=""
RESEND_FROM_EMAIL="空間借用系統 <notify@yourdomain.com>"

# Base URL of this app, used to build absolute links in emails
NEXT_PUBLIC_APP_URL="http://localhost:3000"
